{
  "name": "ai-app-generator-poc",
  "version": "1.0.0",
  "description": "AI App Generator Proof of Concept",
  "scripts": {
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:watch": "jest --coverage --watch",
    "test:unit": "jest --testPathPattern=src/",
    "test:integration": "jest --testPathPattern=server/",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "component-server": "bun run server/component-server.ts",
    "api-server": "bun run server/api-server.ts",
    "dev": "bun run component-server",
    "dev:api": "bun run api-server",
    "dev:all": "concurrently \"npm run component-server\" \"npm run api-server\"",
    "simple-server": "bun run src/simple/server.ts",
    "pod-install": "cd ios && pod install",
    "clean": "rm -rf node_modules/.cache jest-coverage .nyc_output coverage",
    "clean:install": "npm run clean && npm install",
    "health-check": "curl -f http://localhost:3002/health || exit 1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/opossum": "^8.1.9",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@types/react-test-renderer": "^18.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.2.1",
    "bun-types": "latest",
    "concurrently": "^8.2.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.2.1",
    "jest-environment-node": "^29.2.1",
    "jest-extended": "^4.0.0",
    "metro-react-native-babel-preset": "^0.76.8",
    "react-native-codegen": "^0.71.5",
    "react-test-renderer": "18.2.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.1",
    "@ai-sdk/openai": "^2.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "ai": "^5.0.5",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^9.0.0",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "zod": "^3.23.8"
  }
}
