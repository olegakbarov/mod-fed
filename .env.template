# AI App Generator - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Never commit .env files to version control

# Required Server Secrets (REQUIRED)
# Generate these with: openssl rand -hex 32
SERVER_JWT_SECRET=your_jwt_secret_here_min_32_chars
SERVER_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# Optional API Keys for AI Services
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Custom API Keys (optional)
# You can add multiple custom API keys using the pattern CUSTOM_API_KEY_*
# CUSTOM_API_KEY_SERVICE1=your_service1_key
# CUSTOM_API_KEY_SERVICE2=your_service2_key

# Database Configuration (optional)
# DATABASE_URL=your_database_connection_string
# DATABASE_PASSWORD=your_database_password

# Security Configuration
# Trusted proxy IPs (comma-separated, optional)
# Only trust X-Forwarded-For headers from these IPs
TRUSTED_PROXIES=127.0.0.1,::1

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# Development vs Production
NODE_ENV=development

# Demo API Keys (development only)
# These are only used when NODE_ENV=development
DEMO_BASIC_API_KEY=demo-basic-key-12345-replace-in-production
DEMO_PREMIUM_API_KEY=demo-premium-key-67890-replace-in-production

# Server Configuration
PORT=3001
HOST=localhost

# Rate Limiting (optional - defaults provided)
RATE_LIMIT_ANONYMOUS_MAX=10
RATE_LIMIT_AUTH_MAX=50
MAX_PROMPT_LENGTH=500
MAX_BODY_SIZE_BYTES=10240