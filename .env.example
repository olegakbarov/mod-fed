# Required Server Secrets (Generate with: openssl rand -hex 32)
SERVER_JWT_SECRET=your_jwt_secret_here_min_32_chars_long_for_security
SERVER_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars_long_for_security

# AI Provider Configuration
# Choose between 'openai' or 'anthropic'
AI_PROVIDER=openai

# API Key for your chosen provider
# Get your OpenAI API key from: https://platform.openai.com/api-keys
# Get your Anthropic API key from: https://console.anthropic.com/settings/keys
AI_API_KEY=your-api-key-here

# Model to use
# For OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
AI_MODEL=gpt-4o-mini

# Development Configuration
NODE_ENV=development

# Demo API Keys (development only - replace in production)
DEMO_BASIC_API_KEY=demo-basic-key-12345-replace-in-production
DEMO_PREMIUM_API_KEY=demo-premium-key-67890-replace-in-production

# Security Configuration
TRUSTED_PROXIES=127.0.0.1,::1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# Server Configuration
PORT=3001
HOST=localhost

# Rate Limiting (optional)
RATE_LIMIT_ANONYMOUS_MAX=10
RATE_LIMIT_AUTH_MAX=50
MAX_PROMPT_LENGTH=500
MAX_BODY_SIZE_BYTES=10240