{
  "id": "generic-app",
  "name": "Generic Application",
  "description": "A flexible template for creating custom applications",
  "keywords": [],
  "aiTags": ["generic", "custom"],
  "enableDatabase": false,
  "variables": {
    "appTitle": "Generated App",
    "welcomeMessage": "Welcome to your new app",
    "description": "This app was generated based on your requirements"
  },
  "screens": [
    {
      "name": "MainScreen",
      "title": "Main",
      "layout": "vertical",
      "components": [
        {
          "type": "Header",
          "props": {
            "title": "{{appTitle}}"
          },
          "order": 1
        },
        {
          "type": "Card",
          "props": {
            "title": "{{welcomeMessage}}",
            "content": "{{description}}"
          },
          "order": 2
        },
        {
          "type": "Button",
          "props": {
            "label": "Get Started"
          },
          "order": 3
        }
      ]
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "author": "AI Generator",
    "category": "general",
    "difficulty": "beginner",
    "estimatedTime": "2 minutes"
  }
}